# Files that should not be copied into the docker image

.git

# The remaining lines are copied from .gitignore.
# Note that relative paths in .gitignore match items in any subfolder,
# but in .dockerignore they match only items in the project root

# Temporary and binary files
*~
*.py[cod]
*.so
*.cfg
!.isort.cfg
!setup.cfg
*.orig
*.log
*.pot
__pycache__/*
.cache/*
.*.swp
*/.ipynb_checkpoints/*
.DS_Store

# Project files
.ropeproject
.project
.pydevproject
.settings
.idea
.vscode
.python-version
tags

# Package files
*.egg
*.eggs/
.installed.cfg
*.egg-info

# Unittest and coverage
htmlcov/*
.coverage
.tox
junit.xml
coverage.xml
.pytest_cache/

# Build and docs folder/files
build/*
dist/*
sdist/*
docs/api/*
docs/_rst/*
docs/_build/*
cover/*
MANIFEST

# Per-project virtualenvs
.venv*/
venv*/
*.sqlite3

# Custom rules
.env
.scannerwork
staticfiles/*
site/*
src/metax_service/settings/local.py
